# Bearer token accepted by POST/GET /api/refresh. Pick any long random string,
# e.g. `openssl rand -hex 32`. Required for manual or GitHub Actions refreshes.
REFRESH_SECRET=

# Optional: when set in Vercel, Vercel Cron automatically calls /api/refresh
# with `Authorization: Bearer $CRON_SECRET` (see vercel.json for the schedule).
CRON_SECRET=

# Canonical site URL used in metadata, sitemap and robots.
# Defaults to https://isthestraitofhormuzopen.vercel.app when unset.
NEXT_PUBLIC_SITE_URL=
